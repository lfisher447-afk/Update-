{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "**/*",
      "!logs/**",
      "!.git/**"
    ]
  },
  "deploy": {
    "startCommand": "npm run start:prod",
    "healthcheckPath": "/health/ready",
    "healthcheckTimeout": 45,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
